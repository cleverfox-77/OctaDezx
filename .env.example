# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Supabase (safe to expose in frontend — these are public keys)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# GEMINI_API_KEY must ONLY be set in Supabase Edge Function Secrets.
# Do NOT add it here — the VITE_ prefix would expose it in the public JS bundle.
# Set it at: supabase.com/dashboard/project/YOUR_PROJECT/settings/functions
